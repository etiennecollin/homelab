# ----------------------------------------------------------------
# Shared environment
# ----------------------------------------------------------------
{%- if shared_env %}
{%- for key, value in shared_env | dictsort %}
{{ key }}="{{ value }}"
{%- endfor %}
{%- else %}
# (none)
{%- endif %}

# ----------------------------------------------------------------
# Stack-specific environment and overrides
# ----------------------------------------------------------------
{%- if stack_env %}
{%- for key, value in stack_env | dictsort %}
{{ key }}="{{ value }}"
{%- endfor %}
{%- else %}
# (none)
{%- endif %}
